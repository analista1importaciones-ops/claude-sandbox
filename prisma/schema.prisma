generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String      @id @default(cuid())
  email             String      @unique
  name              String
  passwordHash      String
  role              Role        @default(OPERATOR)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  quotations          Quotation[]
  courierQuotations   CourierQuotation[]
  rateSheetsCreated   RateSheet[]
  assignedContacts    Contact[]
  activities          Activity[]
  serviceInvoices     ServiceInvoice[]
}

enum Role {
  ADMIN
  OPERATOR
}

model Carrier {
  id           String      @id @default(cuid())
  name         String
  type         CarrierType
  contactEmail String?
  contactName  String?
  contactPhone String?
  notes        String?
  createdAt    DateTime    @default(now())
  rateSheets   RateSheet[]
}

enum CarrierType {
  NAVIERA
  AGENTE
  CONSOLIDADOR
}

model RateSheet {
  id           String   @id @default(cuid())
  carrierId    String
  carrier      Carrier  @relation(fields: [carrierId], references: [id])
  reference    String
  sourceFile   String?
  sourceFileUrl String?
  receivedAt   DateTime
  notes        String?
  createdById  String
  createdBy    User     @relation(fields: [createdById], references: [id])
  createdAt    DateTime @default(now())
  rates        Rate[]
}

model Rate {
  id              String    @id @default(cuid())
  rateSheetId     String
  rateSheet       RateSheet @relation(fields: [rateSheetId], references: [id], onDelete: Cascade)
  originCountry   String
  originPort      String
  destinationPort String
  mode            ShipMode
  currency        String    @default("USD")
  validFrom       DateTime
  validUntil      DateTime
  freightRate     Decimal?  @db.Decimal(10, 2)
  freightUnit     String?
  baf             Decimal?  @db.Decimal(10, 2)
  caf             Decimal?  @db.Decimal(10, 2)
  isps            Decimal?  @db.Decimal(10, 2)
  thcOrigin       Decimal?  @db.Decimal(10, 2)
  thcDestination  Decimal?  @db.Decimal(10, 2)
  docFee          Decimal?  @db.Decimal(10, 2)
  handling        Decimal?  @db.Decimal(10, 2)
  vgm             Decimal?  @db.Decimal(10, 2)
  customsOrigin   Decimal?  @db.Decimal(10, 2)
  manifest        Decimal?  @db.Decimal(10, 2)
  pickUp          Decimal?  @db.Decimal(10, 2)
  overlength      Decimal?  @db.Decimal(10, 2)
  seal            Decimal?  @db.Decimal(10, 2)
  telexRelease    Decimal?  @db.Decimal(10, 2)
  ams             Decimal?  @db.Decimal(10, 2)
  gri             Decimal?  @db.Decimal(10, 2)
  pss             Decimal?  @db.Decimal(10, 2)
  congestion      Decimal?  @db.Decimal(10, 2)
  cleaningFee     Decimal?  @db.Decimal(10, 2)
  portCharges     Decimal?  @db.Decimal(10, 2)
  warehouse       Decimal?  @db.Decimal(10, 2)
  insurance       Decimal?  @db.Decimal(10, 2)
  otherCharges    Decimal?  @db.Decimal(10, 2)
  otherChargesDesc String?
  transitDaysMin  Int?
  transitDaysMax  Int?
  frequency       String?
  commodity       String?
  notes           String?
  replacedById    String?
  replacedBy      Rate?     @relation("RateReplacement", fields: [replacedById], references: [id])
  replaces        Rate[]    @relation("RateReplacement")
  createdAt       DateTime  @default(now())
  quotations      Quotation[]
}

enum ShipMode {
  LCL
  FCL20
  FCL40
  FCL40HC
  AIR
}

model Port {
  id       String  @id @default(cuid())
  code     String  @unique
  name     String
  country  String
  isCommon Boolean @default(true)
}

model GtlCostConfig {
  id         String       @id @default(cuid())
  key        String       @unique
  label      String
  value      Decimal      @db.Decimal(10, 2)
  appliesIva Boolean      @default(false)
  category   CostCategory
  updatedAt  DateTime     @updatedAt
}

enum CostCategory {
  LOCAL_CHARGES
  THIRD_PARTY
  INLAND_TRANSPORT
  SERVICE_RATES
}

model ServiceInvoice {
  id            String               @id @default(cuid())
  number        String               @unique
  createdById   String
  createdBy     User                 @relation(fields: [createdById], references: [id])
  contactId     String?
  contact       Contact?             @relation(fields: [contactId], references: [id])
  createdAt     DateTime             @default(now())
  issueDate     DateTime             @default(now())
  dueDate       DateTime?
  status        ServiceInvoiceStatus @default(EMITIDA)
  customerName  String
  customerEmail String?
  customerPhone String?
  customerTaxId String?
  customerAddress String?
  serviceTag    String?
  currency      String               @default("USD")
  items         Json
  subtotal      Decimal              @db.Decimal(12, 2)
  ivaTotal      Decimal              @db.Decimal(12, 2)
  total         Decimal              @db.Decimal(12, 2)
  notes         String?
}

enum ServiceInvoiceStatus {
  BORRADOR
  EMITIDA
  PAGADA
  ANULADA
}

model InlandRoute {
  id          String  @id @default(cuid())
  origin      String
  destination String
  costUsd     Decimal @db.Decimal(10, 2)
  notes       String?
}

model Quotation {
  id          String      @id @default(cuid())
  number      String      @unique
  rateId      String?
  rate        Rate?       @relation(fields: [rateId], references: [id])
  createdById String
  createdBy   User        @relation(fields: [createdById], references: [id])
  createdAt   DateTime    @default(now())
  issueDate   DateTime
  validUntil  DateTime
  status      QuoteStatus @default(BORRADOR)
  customerName  String
  customerEmail String?
  customerPhone String?
  originPort         String
  destinationPort    String
  originCountry      String
  destinationCountry String?
  mode               ShipMode
  incoterm           String
  currency           String   @default("USD")
  cbm                Decimal? @db.Decimal(10, 3)
  containers         Int?
  grossWeightKg      Decimal? @db.Decimal(10, 2)
  productDesc        String?
  transitDaysMin     Int?
  transitDaysMax     Int?
  frequency          String?
  intlCharges  Json
  localCharges Json
  otherCharges Json
  intlTotal  Decimal @db.Decimal(10, 2)
  localTotal Decimal @db.Decimal(10, 2)
  otherTotal Decimal @db.Decimal(10, 2)
  grandTotal Decimal @db.Decimal(10, 2)
  notes String?
  deals Deal[]
}

enum QuoteStatus {
  BORRADOR
  ENVIADA
  APROBADA
  EN_TRANSITO
  ARRIBO
  EN_ADUANA
  NACIONALIZACION
  ENTREGADA
  RECHAZADA
}

model CourierQuotation {
  id            String   @id @default(cuid())
  number        String   @unique
  createdById   String
  createdBy     User     @relation(fields: [createdById], references: [id])
  createdAt     DateTime @default(now())
  customerName  String
  customerEmail String?
  customerPhone String?
  originCountry      String
  destinationCountry String
  weightKg           Decimal  @db.Decimal(10, 3)
  lengthCm           Decimal? @db.Decimal(10, 1)
  widthCm            Decimal? @db.Decimal(10, 1)
  heightCm           Decimal? @db.Decimal(10, 1)
  volumetricWeightKg Decimal? @db.Decimal(10, 3)
  chargeableWeightKg Decimal? @db.Decimal(10, 3)
  productDesc        String?
  declaredValueUsd   Decimal? @db.Decimal(12, 2)
  options        Json     @default("[]")
  selectedCarrier  String?
  selectedService  String?
  selectedPriceUsd Decimal? @db.Decimal(10, 2)
  status    CourierStatus @default(BORRADOR)
  notes     String?
  issueDate DateTime      @default(now())
}

enum CourierStatus {
  BORRADOR
  ENVIADA
  APROBADA
  EN_TRANSITO
  ENTREGADA
  RECHAZADA
}

enum LeadSource {
  PAUTA
  REFERIDO
  WEB
  LLAMADA
  FERIA
  OTRO
}

enum ServiceLabel {
  CURSOS
  CARGA
  ASESORIAS
  INSPECCIONES
  BUSQUEDA_PROVEEDORES
  COURIER
  NACIONALIZACION
  TRANSPORTE_PESADO
  SEGURO_CARGA
  OTRO
}

enum PipelineStage {
  PAUTA
  CONTACTADO
  COTIZADO
  SEGUIMIENTO
  NEGOCIANDO
  CERRADO_GANADO
  PERDIDO
}

enum ActivityType {
  LLAMADA
  WHATSAPP
  EMAIL
  NOTA
  REUNION
}

model Contact {
  id             String       @id @default(cuid())
  name           String
  company        String?
  email          String?
  phone          String?
  waName         String?
  tags           String[]
  source         LeadSource   @default(OTRO)
  serviceLabel   ServiceLabel @default(OTRO)
  assignedToId   String?
  assignedTo     User?        @relation(fields: [assignedToId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deals          Deal[]
  activities     Activity[]
  whatsappMessages  WhatsAppMessage[]
  scheduledMessages ScheduledMessage[]
  appointments      Appointment[]
  internalNotes     InternalNote[]
  serviceInvoices   ServiceInvoice[]

  @@index([phone])
  @@index([serviceLabel])
  @@index([createdAt])
}

model Deal {
  id               String        @id @default(cuid())
  contactId        String
  contact          Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  stage            PipelineStage @default(PAUTA)
  estimatedValue   Decimal?      @db.Decimal(12, 2)
  currency         String        @default("USD")
  estimatedCloseAt DateTime?
  quotationId      String?
  quotation        Quotation?    @relation(fields: [quotationId], references: [id])
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  activities       Activity[]

  @@index([contactId])
  @@index([stage])
  @@index([updatedAt])
}

model Activity {
  id          String       @id @default(cuid())
  type        ActivityType @default(NOTA)
  text        String
  contactId   String?
  contact     Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  dealId      String?
  deal        Deal?        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User         @relation(fields: [createdById], references: [id])
  createdAt   DateTime     @default(now())
}

// ─── Sprint 5 WhatsApp ───────────────────────────────────────────

model WhatsAppMessage {
  id          String   @id @default(cuid())
  remoteJid   String
  phoneJid    String?
  fromMe      Boolean  @default(false)
  content     String
  messageId   String   @unique
  timestamp   DateTime
  contactId   String?
  mediaUrl    String?
  mediaType   String?
  waName      String?
  contact     Contact? @relation(fields: [contactId], references: [id])
  createdAt   DateTime @default(now())

  @@index([remoteJid])
  @@index([phoneJid])
  @@index([contactId])
  @@index([timestamp])
}

model WaConversation {
  id          String   @id @default(cuid())
  remoteJid   String   @unique
  phoneJid    String?
  unreadCount Int      @default(0)
  status      String   @default("OPEN")
  updatedAt   DateTime @updatedAt

  @@index([phoneJid])
  @@index([updatedAt])
}

model WhatsAppTemplate {

  id        String   @id @default(cuid())
  name      String
  body      String
  mediaUrl  String?
  mediaType String?
  mediaName String?
  createdAt DateTime @default(now())
  workflows Workflow[]
}

model Workflow {
  id        String         @id @default(cuid())
  name      String
  trigger   WorkflowTrigger
  stage     PipelineStage?
  serviceTag String?
  delayDays Int            @default(0)
  delayHours Int            @default(0)
  delayMinutes Int          @default(0)
  templateId String?
  template  WhatsAppTemplate? @relation(fields: [templateId], references: [id])
  active    Boolean        @default(true)
  createdAt DateTime       @default(now())

  @@index([active, trigger, stage])
  @@index([serviceTag])
}

enum WorkflowTrigger {
  DEAL_STAGE_CHANGED
  NO_ACTIVITY_DAYS
  CONTACT_CREATED
}

// ─── Sprint 8 ────────────────────────────────────────────────────

model QuickReply {
  id        String   @id @default(cuid())
  title     String
  body      String
  createdAt DateTime @default(now())
}

model ScheduledMessage {
  id          String   @id @default(cuid())
  remoteJid   String
  body        String
  mediaUrl    String?
  mediaType   String?
  mediaName   String?
  sendAt      DateTime
  sent        Boolean  @default(false)
  processingAt DateTime?
  contactId   String?
  contact     Contact? @relation(fields: [contactId], references: [id])
  createdAt   DateTime @default(now())

  @@index([sent, sendAt])
  @@index([processingAt])
  @@index([contactId])
}

model WorkflowExecution {
  id         String   @id @default(cuid())
  key        String   @unique
  workflowId String
  contactId  String
  dealId     String?
  stage      String?
  status     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([workflowId])
  @@index([contactId])
  @@index([dealId])
}

model Appointment {
  id              String   @id @default(cuid())
  title           String
  description     String?
  startAt         DateTime
  endAt           DateTime
  contactId       String?
  contact         Contact? @relation(fields: [contactId], references: [id])
  googleEventId   String?
  remoteJid       String?
  notified        Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([startAt])
  @@index([contactId])
}

model GoogleToken {
  id           String   @id @default(cuid())
  accessToken  String
  refreshToken String
  expiryDate   BigInt
  updatedAt    DateTime @updatedAt
}

model InternalNote {
  id        String   @id @default(cuid())
  remoteJid String
  content   String
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])
  createdAt DateTime @default(now())

  @@index([remoteJid])
  @@index([contactId])
}
